generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String   @default("General")
  location    String
  contact     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
